      "content": "<div class=\"min-h-screen bg-[#faf9f6]\">\r\n      \r\n      <header\r\n        style={{\r\n          background:\r\n            'linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1e293b 100%)',\r\n        }}\r\n      >\r\n        <div class=\"max-w-5xl mx-auto px-4 py-14 text-center\">\r\n          <p class=\"text-white/60 text-xs font-bold tracking-[0.12em] uppercase mb-3\">\r\n            ObjectWire\r\n          </p>\r\n          <h1 class=\"text-white font-black text-4xl md:text-5xl mb-4\">\r\n            Topics &amp; Tags\r\n          </h1>\r\n          <p class=\"text-white/75 text-lg max-w-xl mx-auto\">\r\n            Every subject ObjectWire covers — click a tag to see all related\r\n            articles.\r\n          </p>\r\n        </div>\r\n      </header>\r\n\r\n      \r\n      <section class=\"max-w-5xl mx-auto px-4 py-14\">\r\n        <div class=\"flex flex-wrap gap-3 justify-center\">\r\n          {tags.map(({ tag, count }) => (\r\n            <a\r\n              href={`/tags/${encodeURIComponent(tag.toLowerCase().replace(/\\s+/g, '-'))}`}\r\n              class=\"group inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-full shadow-sm hover:shadow-md hover:border-gray-400 transition-all\"\r\n            >\r\n              <span class=\"text-sm font-semibold text-gray-800 group-hover:text-blue-700\">\r\n                {tag}\r\n              </span>\r\n              <span class=\"text-xs font-bold text-gray-400 bg-gray-100 rounded-full px-2 py-0.5\">\r\n                {count}\r\n              </span>\r\n            </a>\r\n          ))}\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <script\r\n        type=\"application/ld+json\"\r\n        dangerouslySetInnerHTML={{\r\n          __html: JSON.stringify({\r\n            '@context': 'https://schema.org',\r\n            '@type': 'CollectionPage',\r\n            name: 'All Topics & Tags',\r\n            description:\r\n              'Index of all topics covered by ObjectWire.',\r\n            url: 'https://www.ozonenetwork.news/tags',\r\n            publisher: {\r\n              '@type': 'Organization',\r\n              name: 'ObjectWire',\r\n              url: 'https://www.ozonenetwork.news',\r\n            },\r\n          }),\r\n        }}\r\n      />\r\n    </div>"
