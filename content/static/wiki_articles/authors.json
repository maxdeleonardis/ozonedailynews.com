{
  "id": "5565dcdc-56dd-4d88-83b4-8cef83b38692",
  "slug": "authors",
  "title": "Authors & Contributors",
  "subtitle": "Meet the journalists, reporters, and editors behind OzoneNews — covering finance, markets, science, technology, anime, gaming, investigations, and breaking news.",
  "content": [
    {
      "id": "html-body",
      "type": "html",
      "content": "<div class=\"min-h-screen bg-[#faf9f6]\">\r\n\r\n        \r\n        <header style={{ background: 'linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1e293b 100%)' }}>\r\n          <div class=\"max-w-5xl mx-auto px-4 py-14 text-center\">\r\n            <p style={{ color: 'rgba(255,255,255,0.6)', fontSize: '0.75rem', fontWeight: 700, letterSpacing: '0.12em', textTransform: 'uppercase', marginBottom: '0.75rem' }}>\r\n              OzoneNews\r\n            </p>\r\n            <h1 style={{ color: '#fff', fontSize: 'clamp(2rem, 5vw, 3rem)', fontWeight: 900, lineHeight: 1.1, marginBottom: '1rem' }}>\r\n              Authors &amp; Contributors\r\n            </h1>\r\n            <p style={{ color: 'rgba(255,255,255,0.75)', fontSize: '1.1rem', maxWidth: '560px', margin: '0 auto 1.5rem' }}>\r\n              The journalists, reporters, and editors behind OzoneNews's verified,\r\n              source-cited reporting.\r\n            </p>\r\n            <div style={{ display: 'flex', justifyContent: 'center', gap: '10px', flexWrap: 'wrap' }}>\r\n              <a href=\"/\"\r\n                style={{ background: 'rgba(255,255,255,0.15)', color: '#fff', padding: '7px 16px', borderRadius: '8px', fontWeight: 600, fontSize: '0.8rem', textDecoration: 'none' }}>\r\n                OzoneNews Home\r\n              </a>\r\n              <a href=\"/editorial-standards\"\r\n                style={{ background: 'rgba(255,255,255,0.1)', color: 'rgba(255,255,255,0.85)', padding: '7px 16px', borderRadius: '8px', fontWeight: 600, fontSize: '0.8rem', textDecoration: 'none' }}>\r\n                Editorial Standards\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </header>\r\n\r\n        \r\n        <section class=\"max-w-5xl mx-auto px-4 py-14\">\r\n          <div class=\"grid gap-8 md:grid-cols-2 lg:grid-cols-3\">\r\n            {authors.map((author) => (\r\n              <a\r\n                href={`/authors/${author.slug}`}\r\n                class=\"group bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-300\"\r\n              >\r\n                \r\n                <div class={`h-20 bg-gradient-to-r ${author.gradient} relative`}>\r\n                  {author.featured && (\r\n                    <span class=\"absolute top-3 right-3 bg-white/20 text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full\">\r\n                      ★ Featured\r\n                    </span>\r\n                  )}\r\n                </div>\r\n\r\n                <div class=\"px-6 pb-6\">\r\n                  \r\n                  <div class={`-mt-10 mb-4 w-20 h-20 rounded-full bg-gradient-to-br ${author.avatarBg} p-0.5 shadow-lg`}>\r\n                    <div class=\"w-full h-full rounded-full bg-white flex items-center justify-center\">\r\n                      <span class=\"text-2xl font-black text-gray-700\">{author.initial}</span>\r\n                    </div>\r\n                  </div>\r\n\r\n                  \r\n                  <h2 class=\"text-xl font-bold text-gray-900 mb-0.5 group-hover:text-blue-700 transition-colors\">\r\n                    {author.name}\r\n                  </h2>\r\n                  <p class={`text-sm font-semibold mb-1 ${author.roleColor}`}>\r\n                    {author.role}\r\n                  </p>\r\n                  <p class=\"text-xs text-gray-400 mb-3\">{author.location}</p>\r\n\r\n                  \r\n                  <p class=\"text-sm text-gray-600 leading-relaxed mb-4 line-clamp-3\">\r\n                    {author.bio}\r\n                  </p>\r\n\r\n                  \r\n                  <div class=\"flex flex-wrap gap-1.5 mb-4\">\r\n                    {author.beats.map((beat) => (\r\n                      <span class=\"px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full text-xs font-medium\">\r\n                        {beat}\r\n                      </span>\r\n                    ))}\r\n                  </div>\r\n\r\n                  \r\n                  {author.recentArticle && (\r\n                    <div class={`rounded-lg border p-3 ${author.badgeBg}`}>\r\n                      <p class=\"text-[10px] font-bold uppercase tracking-wider text-gray-400 mb-1\">\r\n                        Latest Article\r\n                      </p>\r\n                      <p class=\"text-xs font-semibold text-gray-800 line-clamp-2\">\r\n                        {author.recentArticle.title}\r\n                      </p>\r\n                    </div>\r\n                  )}\r\n\r\n                  \r\n                  <div class=\"mt-4 text-sm font-semibold text-blue-600 group-hover:underline flex items-center gap-1\">\r\n                    View profile →\r\n                  </div>\r\n                </div>\r\n              </a>\r\n            ))}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"max-w-5xl mx-auto px-4 pb-16\">\r\n          <div class=\"bg-white border border-gray-200 rounded-2xl p-8 text-center\">\r\n            <h2 class=\"text-xl font-bold text-gray-900 mb-3\">Our Editorial Commitment</h2>\r\n            <p class=\"text-gray-600 max-w-2xl mx-auto text-sm leading-relaxed mb-5\">\r\n              Every OzoneNews author operates under the same editorial principles: verified\r\n              sourcing, factual accuracy, clear separation of news and opinion, and full\r\n              transparency about corrections. No sponsored content without explicit disclosure.\r\n            </p>\r\n            <div class=\"flex flex-wrap justify-center gap-4 text-sm\">\r\n              <a href=\"/editorial-standards\" class=\"text-blue-600 hover:underline font-medium\">\r\n                Read Our Editorial Standards →\r\n              </a>\r\n              <a href=\"/corrections\" class=\"text-blue-600 hover:underline font-medium\">\r\n                Corrections Policy →\r\n              </a>\r\n              <a href=\"/about\" class=\"text-blue-600 hover:underline font-medium\">\r\n                About OzoneNews →\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n      </div>"
    }
  ],
