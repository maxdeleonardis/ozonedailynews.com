# =============================================================================
# ObjectWire — Environment Variables
# Copy this file to .env.local for local development.
# Set ALL of these in your Vercel / hosting dashboard for production.
# NEVER commit .env.local to git.
# =============================================================================


# =============================================================================
# SITE
# =============================================================================

# Production canonical URL (no trailing slash)
NEXTAUTH_URL=https://www.objectwire.org

# For local development uncomment:
# NEXTAUTH_URL=http://localhost:3000


# =============================================================================
# NEXTAUTH — required for Google Sign-In and Discord Comments
# Generate with:  openssl rand -base64 32
# =============================================================================

NEXTAUTH_SECRET=your-random-secret-here


# =============================================================================
# GOOGLE OAUTH — "Sign in with Google" (header + article like/save)
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Add Authorized Redirect URIs:
#        https://www.objectwire.org/api/auth/callback/google
#        http://localhost:3000/api/auth/callback/google
#   5. Add Authorized JavaScript Origins:
#        https://www.objectwire.org
#        http://localhost:3000
# =============================================================================

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# =============================================================================
# DISCORD OAUTH — Discord Comments section
#
# Setup:
#   1. Go to https://discord.com/developers/applications
#   2. New Application → OAuth2 → General
#   3. Add Redirects:
#        https://www.objectwire.org/api/auth/callback/discord
#        http://localhost:3000/api/auth/callback/discord
# =============================================================================

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret


# =============================================================================
# GOOGLE ANALYTICS 4
# =============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-289SD96B57


# =============================================================================
# SUPABASE — database (if used)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# =============================================================================
# BEEHIIV — Newsletter subscription
#
# Setup:
#   1. Go to https://app.beehiiv.com → Settings → API
#   2. Create a new API key with "Write" permissions
#   3. Your Publication ID is in Settings → Publication → scroll to "Publication ID"
#      (format: pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# =============================================================================

BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# =============================================================================
# DISCORD COMMENTS — Forum Channel webhook
#
# Setup:
#   1. Create a Forum Channel in your Discord server (e.g. #article-discussion)
#   2. Server Settings → Integrations → Webhooks → New Webhook
#   3. Point the webhook at the Forum Channel
#   4. Copy the webhook URL below
# =============================================================================

DISCORD_COMMENTS_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
