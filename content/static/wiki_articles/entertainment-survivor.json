    {
      "id": "html-body",
      "type": "html",
      "content": "<main class=\"min-h-screen bg-white\">\r\n      \r\n      <div class=\"bg-gradient-to-r from-orange-700 via-red-700 to-orange-800 text-white\">\r\n        <div class=\"container mx-auto px-4 py-16 max-w-7xl\">\r\n          <div class=\"max-w-4xl mx-auto text-center\">\r\n            <div class=\"inline-block bg-yellow-400 text-gray-900 px-4 py-2 rounded-full text-sm font-bold mb-4\">\r\n              🏝️ HISTORIC MILESTONE SEASON\r\n            </div>\r\n            <h1 class=\"text-5xl md:text-7xl font-bold mb-6 leading-tight text-white\">\r\n              Survivor Season 50\r\n            </h1>\r\n            <p class=\"text-xl md:text-2xl text-gray-50 mb-8 leading-relaxed\">\r\n              CBS's legendary reality competition reaches an <strong class=\"text-white\">unprecedented milestone</strong> with \r\n              its 50th season, promising the <strong class=\"text-white\">biggest twists, most epic challenges, \r\n              and unforgettable moments</strong> in the show's 25-year history.\r\n            </p>\r\n            \r\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 text-center\">\r\n              <div class=\"bg-white/10 backdrop-blur rounded-lg p-4\">\r\n                <p class=\"text-3xl font-bold text-white mb-1\">50</p>\r\n                <p class=\"text-xs text-gray-100\">Seasons</p>\r\n              </div>\r\n              <div class=\"bg-white/10 backdrop-blur rounded-lg p-4\">\r\n                <p class=\"text-3xl font-bold text-white mb-1\">25</p>\r\n                <p class=\"text-xs text-gray-100\">Years</p>\r\n              </div>\r\n              <div class=\"bg-white/10 backdrop-blur rounded-lg p-4\">\r\n                <p class=\"text-3xl font-bold text-white mb-1\">$1M</p>\r\n                <p class=\"text-xs text-gray-100\">Grand Prize</p>\r\n              </div>\r\n              <div class=\"bg-white/10 backdrop-blur rounded-lg p-4\">\r\n                <p class=\"text-3xl font-bold text-white mb-1\">39</p>\r\n                <p class=\"text-xs text-gray-100\">Days</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      \r\n      <div class=\"container mx-auto px-4 py-12 max-w-7xl\">\r\n        \r\n        \r\n        <section class=\"mb-16\">\r\n          <div class=\"bg-gradient-to-r from-red-50 to-orange-50 border-l-4 border-red-600 rounded-lg p-6\">\r\n            <div class=\"flex items-start\">\r\n              <span class=\"text-3xl mr-4\">🔥</span>\r\n              <div>\r\n                <h3 class=\"font-bold text-lg text-gray-900 mb-2\">JUST ANNOUNCED</h3>\r\n                <p class=\"text-gray-700 mb-3\">\r\n                  CBS has officially confirmed Survivor Season 50 will premiere in <strong>Fall 2026</strong> with a \r\n                  special <strong>90-minute premiere episode</strong>. Jeff Probst promises this will be \r\n                  \"the most ambitious season we've ever attempted.\"\r\n                </p>\r\n                <p class=\"text-sm text-gray-600\">\r\n                  <strong>Last Updated:</strong> January 15, 2026\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            What We Know About Season 50\r\n          </h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 gap-8\">\r\n            <div class=\"prose prose-lg max-w-none\">\r\n              <h3 class=\"text-2xl font-bold text-gray-900 mb-4\">A Historic Milestone</h3>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                Survivor Season 50 marks a quarter-century of the groundbreaking reality competition that changed \r\n                television forever. Since its debut in May 2000, Survivor has become a cultural phenomenon, launching \r\n                countless careers and creating some of the most memorable moments in TV history.\r\n              </p>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                For this landmark season, CBS and production company SEG (Survivor Entertainment Group) are pulling \r\n                out all the stops. Early reports suggest a format that honors the show's past while pushing into \r\n                bold new territory with twists never before seen in the franchise.\r\n              </p>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                Host Jeff Probst, who has been with the show since day one, has teased that Season 50 will feature \r\n                \"elements that fans have been requesting for years\" along with surprises that will \"redefine what \r\n                Survivor can be.\"\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-gradient-to-br from-orange-50 to-red-50 rounded-xl p-6 border-2 border-orange-200\">\r\n              <h3 class=\"font-bold text-xl mb-4 text-gray-900\">Season Details</h3>\r\n              <dl class=\"space-y-4\">\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Season Number</dt>\r\n                  <dd class=\"font-bold text-gray-900 text-lg\">50</dd>\r\n                </div>\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Premiere Date</dt>\r\n                  <dd class=\"font-bold text-gray-900\">Fall 2026 (Exact date TBA)</dd>\r\n                </div>\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Network</dt>\r\n                  <dd class=\"font-bold text-gray-900\">CBS & Paramount+</dd>\r\n                </div>\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Host</dt>\r\n                  <dd class=\"font-bold text-gray-900\">Jeff Probst</dd>\r\n                </div>\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Length</dt>\r\n                  <dd class=\"font-bold text-gray-900\">39 Days (Classic Format)</dd>\r\n                </div>\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Location</dt>\r\n                  <dd class=\"font-bold text-gray-900\">Fiji (Rumored: Special location)</dd>\r\n                </div>\r\n                <div class=\"border-b border-orange-200 pb-3\">\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Contestants</dt>\r\n                  <dd class=\"font-bold text-gray-900\">20+ (Rumored: Expanded cast)</dd>\r\n                </div>\r\n                <div>\r\n                  <dt class=\"text-sm text-gray-600 mb-1\">Grand Prize</dt>\r\n                  <dd class=\"font-bold text-green-600 text-lg\">$1,000,000</dd>\r\n                </div>\r\n              </dl>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            Theme & Format Speculation\r\n          </h2>\r\n          \r\n          <div class=\"space-y-6\">\r\n            \r\n            <div class=\"bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl p-6 border-2 border-green-200\">\r\n              <div class=\"flex items-center mb-4\">\r\n                <span class=\"text-3xl mr-3\">✅</span>\r\n                <h3 class=\"text-xl font-bold text-gray-900\">Confirmed Elements</h3>\r\n              </div>\r\n              <ul class=\"space-y-3\">\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-green-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Return to Classic 39-Day Format</p>\r\n                    <p class=\"text-sm text-gray-600\">After seasons 41-49 featured the condensed 26-day format, Season 50 returns to the full 39 days</p>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-green-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">90-Minute Premiere Special</p>\r\n                    <p class=\"text-sm text-gray-600\">Extended premiere to kick off the milestone season</p>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-green-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Jeff Probst Hosting</p>\r\n                    <p class=\"text-sm text-gray-600\">The legendary host returns for his 50th season</p>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-green-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Reunion Show</p>\r\n                    <p class=\"text-sm text-gray-600\">Live reunion special featuring surprise guests from all 50 seasons</p>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n\r\n            \r\n            <div class=\"bg-gradient-to-br from-yellow-50 to-orange-50 rounded-xl p-6 border-2 border-yellow-300\">\r\n              <div class=\"flex items-center mb-4\">\r\n                <span class=\"text-3xl mr-3\">🤔</span>\r\n                <h3 class=\"text-xl font-bold text-gray-900\">Rumored Twists & Features</h3>\r\n              </div>\r\n              <ul class=\"space-y-3\">\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-yellow-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">\"Legends vs. Newbies\" Theme</p>\r\n                    <p class=\"text-sm text-gray-600\">Returning winners competing against first-time players</p>\r\n                    <span class=\"inline-block bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded mt-1\">UNCONFIRMED</span>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-yellow-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Expanded Cast of 24 Players</p>\r\n                    <p class=\"text-sm text-gray-600\">Largest cast in modern Survivor history</p>\r\n                    <span class=\"inline-block bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded mt-1\">RUMORED</span>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-yellow-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Special Location Outside Fiji</p>\r\n                    <p class=\"text-sm text-gray-600\">Possible return to an iconic past location like Australia or Pearl Islands</p>\r\n                    <span class=\"inline-block bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded mt-1\">SPECULATION</span>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-yellow-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Increased Prize Money</p>\r\n                    <p class=\"text-sm text-gray-600\">Rumors of $2 million grand prize for the milestone season</p>\r\n                    <span class=\"inline-block bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded mt-1\">SPECULATION</span>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-yellow-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Fan Vote Twist</p>\r\n                    <p class=\"text-sm text-gray-600\">Viewers potentially influencing game elements</p>\r\n                    <span class=\"inline-block bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded mt-1\">RUMORED</span>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-yellow-600 text-lg mr-3 mt-1\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">Classic Challenges Return</p>\r\n                    <p class=\"text-sm text-gray-600\">Iconic challenges from past seasons making a comeback</p>\r\n                    <span class=\"inline-block bg-green-100 text-green-800 text-xs px-2 py-1 rounded mt-1\">LIKELY</span>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            Casting & Potential Players\r\n          </h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 gap-8\">\r\n            <div>\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-4\">🆕 New Players</h3>\r\n              <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n                <p class=\"text-gray-700 mb-4\">\r\n                  CBS opened casting for Season 50 in late 2025, with applications flooding in from superfans \r\n                  eager to be part of the historic milestone season. Casting directors have emphasized they're \r\n                  looking for \"characters who embody the spirit of Survivor.\"\r\n                </p>\r\n                <div class=\"bg-blue-50 rounded-lg p-4 border border-blue-200\">\r\n                  <p class=\"text-sm font-medium text-gray-900 mb-2\">What Casting is Looking For:</p>\r\n                  <ul class=\"text-sm text-gray-700 space-y-1\">\r\n                    <li>• Strategic gamers with fresh ideas</li>\r\n                    <li>• Physically fit competitors</li>\r\n                    <li>• Diverse backgrounds and perspectives</li>\r\n                    <li>• Compelling personal stories</li>\r\n                    <li>• True Survivor superfans</li>\r\n                  </ul>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div>\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-4\">🏆 Potential Returnees</h3>\r\n              <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n                <p class=\"text-gray-700 mb-4\">\r\n                  If the \"Legends vs. Newbies\" theme proves true, fans are speculating about which past winners \r\n                  or memorable players might return. Social media has been buzzing with wishlists.\r\n                </p>\r\n                <div class=\"bg-orange-50 rounded-lg p-4 border border-orange-200\">\r\n                  <p class=\"text-sm font-medium text-gray-900 mb-2\">Fan-Requested Returnees:</p>\r\n                  <ul class=\"text-sm text-gray-700 space-y-1\">\r\n                    <li>• Parvati Shallow (Winner, S16)</li>\r\n                    <li>• Tony Vlachos (2-time winner)</li>\r\n                    <li>• Sandra Diaz-Twine (2-time winner)</li>\r\n                    <li>• Boston Rob Mariano (Winner, S22)</li>\r\n                    <li>• Cirie Fields (Fan favorite)</li>\r\n                    <li>• Yul Kwon (Winner, S13)</li>\r\n                  </ul>\r\n                  <p class=\"text-xs text-gray-500 mt-3 italic\">Note: No returnees officially confirmed</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            Production Timeline\r\n          </h2>\r\n          \r\n          <div class=\"space-y-4\">\r\n            <div class=\"flex items-start\">\r\n              <div class=\"bg-green-500 rounded-full p-3 mr-4\">\r\n                <span class=\"text-white font-bold\">✓</span>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <div class=\"bg-white rounded-lg p-4 border-2 border-green-200\">\r\n                  <p class=\"font-bold text-gray-900 mb-1\">Q4 2025 - Casting Complete</p>\r\n                  <p class=\"text-sm text-gray-600\">Final cast selected and medicals completed</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"flex items-start\">\r\n              <div class=\"bg-blue-500 rounded-full p-3 mr-4\">\r\n                <span class=\"text-white font-bold\">→</span>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <div class=\"bg-gradient-to-br from-blue-50 to-indigo-50 rounded-lg p-4 border-2 border-blue-200\">\r\n                  <p class=\"font-bold text-gray-900 mb-1\">Q1 2026 - Pre-Production</p>\r\n                  <p class=\"text-sm text-gray-600\">Location scouting, challenge design, crew preparation</p>\r\n                  <span class=\"inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded mt-2\">IN PROGRESS</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"flex items-start\">\r\n              <div class=\"bg-orange-500 rounded-full p-3 mr-4\">\r\n                <span class=\"text-white font-bold\">◉</span>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <div class=\"bg-gradient-to-br from-orange-50 to-yellow-50 rounded-lg p-4 border-2 border-orange-200\">\r\n                  <p class=\"font-bold text-gray-900 mb-1\">Spring 2026 - Filming</p>\r\n                  <p class=\"text-sm text-gray-600\">39 days of competition (April-May estimated)</p>\r\n                  <span class=\"inline-block bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded mt-2\">UPCOMING</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"flex items-start\">\r\n              <div class=\"bg-purple-500 rounded-full p-3 mr-4\">\r\n                <span class=\"text-white font-bold\">○</span>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <div class=\"bg-white rounded-lg p-4 border-2 border-purple-200\">\r\n                  <p class=\"font-bold text-gray-900 mb-1\">Summer 2026 - Post-Production</p>\r\n                  <p class=\"text-sm text-gray-600\">Editing, music, promo creation</p>\r\n                  <span class=\"inline-block bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded mt-2\">FUTURE</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"flex items-start\">\r\n              <div class=\"bg-red-600 rounded-full p-3 mr-4\">\r\n                <span class=\"text-white font-bold text-lg\">📺</span>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <div class=\"bg-gradient-to-br from-red-50 to-pink-50 rounded-lg p-4 border-2 border-red-200\">\r\n                  <p class=\"font-bold text-gray-900 mb-1\">Fall 2026 - Premiere</p>\r\n                  <p class=\"text-sm text-gray-600\">90-minute premiere event on CBS (September-October estimated)</p>\r\n                  <span class=\"inline-block bg-red-100 text-red-800 text-xs px-2 py-1 rounded mt-2\">ANTICIPATED</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            What Jeff Probst Is Saying\r\n          </h2>\r\n          \r\n          <div class=\"space-y-6\">\r\n            <div class=\"bg-gradient-to-r from-orange-50 to-red-50 rounded-xl p-6 border-l-4 border-orange-600\">\r\n              <p class=\"text-gray-700 text-lg italic mb-3\">\r\n                \"Season 50 is going to be everything fans love about Survivor, amplified. We're honoring our history \r\n                while creating the future of the show. I can't wait for people to see what we have planned.\"\r\n              </p>\r\n              <p class=\"text-sm text-gray-600\">— Jeff Probst, December 2025 interview</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6 border-l-4 border-blue-600\">\r\n              <p class=\"text-gray-700 text-lg italic mb-3\">\r\n                \"The 39-day format is back because this season deserves the epic scope. We're not rushing anything. \r\n                We want to let the story breathe and give these players the full Survivor experience.\"\r\n              </p>\r\n              <p class=\"text-sm text-gray-600\">— Jeff Probst, CBS upfronts, November 2025</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gradient-to-r from-yellow-50 to-orange-50 rounded-xl p-6 border-l-4 border-yellow-600\">\r\n              <p class=\"text-gray-700 text-lg italic mb-3\">\r\n                \"We listened to the fans. Season 50 incorporates elements that people have been asking for, but we're \r\n                also taking risks. Some twists will surprise even the most hardcore Survivor scholars.\"\r\n              </p>\r\n              <p class=\"text-sm text-gray-600\">— Jeff Probst, Entertainment Weekly, January 2026</p>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            25 Years of Survivor\r\n          </h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8\">\r\n            <div class=\"bg-gradient-to-br from-orange-50 to-yellow-50 rounded-xl p-6 border-2 border-orange-200 text-center\">\r\n              <p class=\"text-4xl font-bold text-gray-900 mb-2\">50</p>\r\n              <p class=\"text-sm text-gray-600\">Seasons</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border-2 border-blue-200 text-center\">\r\n              <p class=\"text-4xl font-bold text-gray-900 mb-2\">750+</p>\r\n              <p class=\"text-sm text-gray-600\">Episodes Aired</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl p-6 border-2 border-green-200 text-center\">\r\n              <p class=\"text-4xl font-bold text-gray-900 mb-2\">800+</p>\r\n              <p class=\"text-sm text-gray-600\">Contestants</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gradient-to-br from-red-50 to-pink-50 rounded-xl p-6 border-2 border-red-200 text-center\">\r\n              <p class=\"text-4xl font-bold text-gray-900 mb-2\">25</p>\r\n              <p class=\"text-sm text-gray-600\">Years on Air</p>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"prose prose-lg max-w-none\">\r\n            <h3 class=\"text-2xl font-bold text-gray-900 mb-4\">The Show That Changed Television</h3>\r\n            <p class=\"text-gray-700 mb-4\">\r\n              When Survivor premiered on May 31, 2000, it revolutionized television. The show's blend of social strategy, \r\n              physical competition, and survival elements created a new genre that spawned countless imitators but never \r\n              equals.\r\n            </p>\r\n            <p class=\"text-gray-700 mb-4\">\r\n              Over 25 years, Survivor has taken viewers to exotic locations around the world, from the Australian Outback \r\n              to the Pearl Islands of Panama to the Fiji islands that have become its home base. The show has created \r\n              cultural touchstones, launched careers, and introduced gameplay concepts that are now part of the lexicon.\r\n            </p>\r\n            <p class=\"text-gray-700 mb-4\">\r\n              Season 50 represents not just a number, but a testament to Survivor's enduring appeal and its ability to \r\n              evolve while maintaining the core elements that made it special from day one.\r\n            </p>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            Iconic Moments Leading to Season 50\r\n          </h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n            <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n              <div class=\"text-4xl mb-3\">🔥</div>\r\n              <h3 class=\"font-bold text-gray-900 mb-2\">The First Vote</h3>\r\n              <p class=\"text-sm text-gray-600 mb-2\">Season 1 - Borneo</p>\r\n              <p class=\"text-sm text-gray-700\">\r\n                Richard Hatch's strategic gameplay set the template for 49 seasons to follow\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n              <div class=\"text-4xl mb-3\">🐐</div>\r\n              <h3 class=\"font-bold text-gray-900 mb-2\">Boston Rob & Amber</h3>\r\n              <p class=\"text-sm text-gray-600 mb-2\">Season 8 - All-Stars</p>\r\n              <p class=\"text-sm text-gray-700\">\r\n                Romance, strategy, and a proposal that became reality TV gold\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n              <div class=\"text-4xl mb-3\">👑</div>\r\n              <h3 class=\"font-bold text-gray-900 mb-2\">Sandra's Second Win</h3>\r\n              <p class=\"text-sm text-gray-600 mb-2\">Season 20 - Heroes vs. Villains</p>\r\n              <p class=\"text-sm text-gray-700\">\r\n                \"The Queen stays Queen\" - becoming the only two-time winner (at the time)\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n              <div class=\"text-4xl mb-3\">🕵️</div>\r\n              <h3 class=\"font-bold text-gray-900 mb-2\">Tony's Spy Bunker</h3>\r\n              <p class=\"text-sm text-gray-600 mb-2\">Season 28 - Cagayan</p>\r\n              <p class=\"text-sm text-gray-700\">\r\n                Chaotic gameplay that somehow led to a million-dollar win\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n              <div class=\"text-4xl mb-3\">🌟</div>\r\n              <h3 class=\"font-bold text-gray-900 mb-2\">David vs. Goliath</h3>\r\n              <p class=\"text-sm text-gray-600 mb-2\">Season 37</p>\r\n              <p class=\"text-sm text-gray-700\">\r\n                One of the most beloved modern seasons with incredible gameplay\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-white rounded-xl p-6 border-2 border-gray-200\">\r\n              <div class=\"text-4xl mb-3\">🏝️</div>\r\n              <h3 class=\"font-bold text-gray-900 mb-2\">Winners at War</h3>\r\n              <p class=\"text-sm text-gray-600 mb-2\">Season 40</p>\r\n              <p class=\"text-sm text-gray-700\">\r\n                All-winner season with $2M prize and Edge of Extinction drama\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-orange-600\">\r\n            How to Watch Season 50\r\n          </h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 gap-8\">\r\n            <div class=\"bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border-2 border-blue-200\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-4\">📺 Live Broadcast</h3>\r\n              <ul class=\"space-y-3 text-sm\">\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-blue-600 text-lg mr-3\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">CBS Television Network</p>\r\n                    <p class=\"text-gray-600\">Wednesday nights at 8/7c (schedule TBA)</p>\r\n                  </div>\r\n                </li>\r\n                <li class=\"flex items-start\">\r\n                  <span class=\"text-blue-600 text-lg mr-3\">•</span>\r\n                  <div>\r\n                    <p class=\"font-medium text-gray-900\">90-Minute Premiere</p>\r\n                    <p class=\"text-gray-600\">Extended premiere episode to kick off the season</p>\r\n                  </div>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n\r\n            <div class=\"bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl p-6 border-2 border-purple-200\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-4\">📱 Streaming</h3>\r\n              <ul class=\"space-y-3 text-sm\">\r\n                <