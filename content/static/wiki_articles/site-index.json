{
  "id": "6f96397a-847f-4403-94b0-c08c5480fc73",
  "slug": "site-index",
  "title": "Site Index",
  "subtitle": "",
  "content": [
    {
      "id": "html-body",
      "type": "html",
      "content": "<main class=\"min-h-screen bg-white\">\r\n      <div class=\"container mx-auto px-4 py-12 max-w-7xl\">\r\n\r\n        \r\n        <section class=\"mb-10\">\r\n          <h1 class=\"text-4xl font-extrabold text-gray-900 mb-3\">Site Index</h1>\r\n          <p class=\"text-gray-600 text-lg max-w-3xl\">\r\n            Every page on ObjectWire, organised by category and sorted newest first.\r\n            This index is auto-populated from the content registry — no manual updates needed.\r\n          </p>\r\n          <div class=\"mt-6 flex flex-wrap gap-4\">\r\n            <div class=\"bg-blue-50 border border-blue-200 rounded-lg px-5 py-3 text-center\">\r\n              <div class=\"text-2xl font-bold text-blue-700\">{totalEntries}</div>\r\n              <div class=\"text-xs text-blue-600 uppercase tracking-wide\">Registered Pages</div>\r\n            </div>\r\n            <div class=\"bg-indigo-50 border border-indigo-200 rounded-lg px-5 py-3 text-center\">\r\n              <div class=\"text-2xl font-bold text-indigo-700\">{totalCategories}</div>\r\n              <div class=\"text-xs text-indigo-600 uppercase tracking-wide\">Categories</div>\r\n            </div>\r\n            {latestEntry && (\r\n              <div class=\"bg-green-50 border border-green-200 rounded-lg px-5 py-3 text-center\">\r\n                <div class=\"text-sm font-bold text-green-700 max-w-[200px] truncate\">{latestEntry.title}</div>\r\n                <div class=\"text-xs text-green-600 uppercase tracking-wide\">\r\n                  Latest · {formatDate(latestEntry.publishDate)}\r\n                </div>\r\n              </div>\r\n            )}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-10\">\r\n          <div class=\"flex flex-wrap gap-2\">\r\n            {categories.map((cat) => {\r\n              const m = CATEGORY_META[cat] ?? DEFAULT_META;\r\n              return (\r\n                <a\r\n                  href={`#cat-${cat.toLowerCase().replace(/\\s+/g, '-')}`}\r\n                  class=\"text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded-full transition-colors\"\r\n                >\r\n                  {m.icon} {cat} <span class=\"text-gray-400 ml-1\">({grouped[cat].length})</span>\r\n                </a>\r\n              );\r\n            })}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-14\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-8 pb-4 border-b-2 border-blue-600\">\r\n            All Pages by Category\r\n          </h2>\r\n          <div class=\"space-y-12\">\r\n            {categories.map((cat) => {\r\n              const entries = grouped[cat];\r\n              const m = CATEGORY_META[cat] ?? DEFAULT_META;\r\n              const anchorId = `cat-${cat.toLowerCase().replace(/\\s+/g, '-')}`;\r\n              return (\r\n                <div id={anchorId}>\r\n                  <div class={`bg-gradient-to-r ${m.gradient} border-2 ${m.border} rounded-xl px-6 py-4 mb-4 flex items-center justify-between`}>\r\n                    <h3 class=\"text-xl font-bold text-gray-900 flex items-center gap-2\">\r\n                      <span class=\"text-2xl\">{m.icon}</span>\r\n                      {cat}\r\n                    </h3>\r\n                    <span class=\"text-sm text-gray-500 font-medium\">\r\n                      {entries.length} page{entries.length !== 1 ? 's' : ''}\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"divide-y divide-gray-100 border border-gray-200 rounded-xl overflow-hidden\">\r\n                    {entries.map((entry) => (\r\n                      <div\r\n                        class=\"flex flex-col sm:flex-row sm:items-start gap-2 px-5 py-4 hover:bg-gray-50 transition-colors group\"\r\n                      >\r\n                        <div class=\"flex-1 min-w-0\">\r\n                          <div class=\"flex flex-wrap items-center gap-2 mb-1\">\r\n                            <a\r\n                              href={entry.slug}\r\n                              class=\"font-semibold text-blue-600 group-hover:text-blue-800 group-hover:underline leading-snug\"\r\n                            >\r\n                              {entry.title}\r\n                            </a>\r\n                            {entry.featured && (\r\n                              <span class=\"text-xs bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full font-medium\">\r\n                                Featured\r\n                              </span>\r\n                            )}\r\n                          </div>\r\n                          {entry.description && (\r\n                            <p class=\"text-sm text-gray-600 line-clamp-2\">{entry.description}</p>\r\n                          )}\r\n                          {entry.tags && entry.tags.length > 0 && (\r\n                            <div class=\"flex flex-wrap gap-1 mt-1.5\">\r\n                              {entry.tags.slice(0, 5).map((tag) => (\r\n                                <span class=\"text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded\">\r\n                                  {tag}\r\n                                </span>\r\n                              ))}\r\n                            </div>\r\n                          )}\r\n                        </div>\r\n                        <div class=\"flex-shrink-0 flex sm:flex-col items-start sm:items-end gap-2 sm:gap-1 text-xs text-gray-400 whitespace-nowrap mt-1 sm:mt-0\">\r\n                          <span class=\"font-mono bg-gray-100 px-2 py-1 rounded text-gray-500\">{entry.slug}</span>\r\n                          <time dateTime={entry.publishDate}>{formatDate(entry.publishDate)}</time>\r\n                          {entry.author && (\r\n                            <span class=\"text-gray-400 italic hidden sm:block\">{entry.author}</span>\r\n                          )}\r\n                        </div>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n              );\r\n            })}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <CoverageMap showLatest={true} />\r\n\r\n        \r\n        <section class=\"mb-12 mt-12\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6 pb-4 border-b-2 border-blue-600\">\r\n            How This Index Works\r\n          </h2>\r\n          <div class=\"bg-gray-50 rounded-xl p-6 border-2 border-gray-200\">\r\n            <div class=\"grid md:grid-cols-2 gap-8\">\r\n              <div>\r\n                <h3 class=\"font-bold text-gray-900 mb-3\">Content Registry</h3>\r\n                <p class=\"text-sm text-gray-700 mb-3\">\r\n                  This index is driven by \r\n                  <code class=\"bg-gray-200 px-1.5 py-0.5 rounded text-xs\">lib/content-registry.ts</code> — \r\n                  a central array of every registered page. Adding a new entry there automatically \r\n                  surfaces it here, in the sitemap, and in related-article feeds.\r\n                </p>\r\n                <p class=\"text-sm text-gray-700\">\r\n                  Entries carry rich metadata: title, description, author, publish date, category, \r\n                  tags, and SEO priority.\r\n                </p>\r\n              </div>\r\n              <div>\r\n                <h3 class=\"font-bold text-gray-900 mb-3\">Features</h3>\r\n                <ul class=\"text-sm text-gray-700 space-y-2\">\r\n                  {[\r\n                    'Auto-populated from content-registry — zero manual updates',\r\n                    'Grouped by category with article counts',\r\n                    'Sorted newest-first within each category',\r\n                    'Inline tags, descriptions, and publish dates',\r\n                    'Jump-links to each category section',\r\n                  ].map((f) => (\r\n                    <li class=\"flex items-start gap-2\">\r\n                      <span class=\"text-green-600 mt-0.5\">✓</span>\r\n                      <span>{f}</span>\r\n                    </li>\r\n                  ))}\r\n                </ul>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section>\r\n          <div class=\"bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 rounded-xl p-12 text-center text-white\">\r\n            <h2 class=\"text-3xl font-bold mb-4\">Explore ObjectWire</h2>\r\n            <p class=\"text-lg mb-8 text-blue-100\">\r\n              Use this index to navigate all our content, or start from the home page.\r\n            </p>\r\n            <a\r\n              href=\"/\"\r\n              class=\"inline-block bg-white text-blue-600 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors font-bold text-lg\"\r\n            >\r\n              Back to Home →\r\n            </a>\r\n          </div>\r\n        </section>\r\n\r\n      </div>\r\n    </main>"
    }
  ],
