          'Saber Interactive',
          'Knights of the Old Republic',
          'Tim Willits',
          'Star Wars game 2026',
          'KOTOR remake development',
        ]}
      />

      <div className="container mx-auto px-4 pt-4 max-w-5xl">
        <Breadcrumb items={breadcrumbItems} />
      </div>

      <NewsArticle
        title="KOTOR Remake Still in Development, Saber Says — 5 Years After Reveal With Nothing to Show"
        subtitle="Saber Interactive's CCO Tim Willits confirmed the Star Wars: Knights of the Old Republic remake is still alive with exactly 11 words. After half a decade of silence, developer shuffles, and a scrubbed Sony marketing page, it's the most expensive confirmation of 'we're working on it' in gaming history."
        category="Gaming"
        categoryColor="blue"
        topicTag="gaming"
        publishDate="March 7, 2026"
