# =============================================================================
# ObjectWire — Environment Variables
# Copy this file to .env.local for local development.
# Set ALL of these in your Vercel / hosting dashboard for production.
# NEVER commit .env.local to git.
# =============================================================================


# =============================================================================
# SITE
# =============================================================================

# Production canonical URL (no trailing slash)
NEXTAUTH_URL=https://www.objectwire.org

# For local development uncomment:
# NEXTAUTH_URL=http://localhost:3000


# =============================================================================
# NEXTAUTH — required for Google Sign-In and Discord Comments
# Generate with:  openssl rand -base64 32
# =============================================================================

NEXTAUTH_SECRET=your-random-secret-here


# =============================================================================
# GOOGLE OAUTH — "Sign in with Google" (header + article like/save)
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Add Authorized Redirect URIs:
#        https://www.objectwire.org/api/auth/callback/google
#        http://localhost:3000/api/auth/callback/google
#   5. Add Authorized JavaScript Origins:
#        https://www.objectwire.org
#        http://localhost:3000
# =============================================================================

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# =============================================================================
# DISCORD OAUTH — Discord Comments section
#
# Setup:
#   1. Go to https://discord.com/developers/applications
#   2. New Application → OAuth2 → General
#   3. Add Redirects:
#        https://www.objectwire.org/api/auth/callback/discord
#        http://localhost:3000/api/auth/callback/discord
# =============================================================================

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret


# =============================================================================
# GOOGLE ANALYTICS 4
# =============================================================================

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-289SD96B57

# GA4 Data API — server-side only (article 7-day view counts, Most Read section)
# Property ID format: "properties/XXXXXXXXX"  (numeric ID from GA4 Admin → Property Settings)
# Service account: go to GCP Console → IAM → Service Accounts → create key (JSON)
#   then paste the entire JSON file as a single line string here.
# Grant the service account "Viewer" access in GA4 Admin → Property → Property Access Management.
GA4_PROPERTY_ID=properties/449132153
GA4_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com"}


# =============================================================================
# SUPABASE — database (if used)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
