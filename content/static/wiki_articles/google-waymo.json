  "content": [
    {
      "id": "html-body",
      "type": "html",
      "content": "<main class=\"min-h-screen bg-white\">\r\n      \r\n      <div class=\"bg-gradient-to-r from-blue-600 via-cyan-500 to-blue-700 text-white\">\r\n        <div class=\"container mx-auto px-4 py-16 max-w-7xl\">\r\n          <div class=\"max-w-4xl\">\r\n            \r\n            <nav class=\"mb-6 text-sm text-blue-100\">\r\n              <a href=\"/google\" class=\"hover:text-white\">Google & Alphabet</a>\r\n              <span class=\"mx-2\">/</span>\r\n              <span class=\"text-white font-semibold\">Waymo</span>\r\n            </nav>\r\n\r\n            <div class=\"flex items-center gap-3 mb-4\">\r\n              <span class=\"text-5xl\">🚗</span>\r\n              <h1 class=\"text-5xl md:text-6xl font-bold\">\r\n                Waymo\r\n              </h1>\r\n            </div>\r\n            <p class=\"text-xl text-gray-100 leading-relaxed mb-6\">\r\n              Comprehensive coverage of Waymo's autonomous vehicle technology, robotaxi operations, safety investigations, \r\n              and the evolution of self-driving transportation.\r\n            </p>\r\n            <div class=\"flex flex-wrap gap-3 text-sm\">\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Autonomous Driving</span>\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Safety & Regulation</span>\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Technology</span>\r\n              <span class=\"bg-red-500/80 px-4 py-2 rounded-full font-semibold animate-pulse\">Under Investigation</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      \r\n      <div class=\"bg-red-600 text-white\">\r\n        <div class=\"container mx-auto px-4 py-4 max-w-7xl\">\r\n          <div class=\"flex items-center gap-4\">\r\n            <span class=\"bg-white text-red-600 text-xs font-bold px-3 py-1 animate-pulse shrink-0\">\r\n              BREAKING\r\n            </span>\r\n            <p class=\"font-semibold\">\r\n              NTSB opens federal investigation into Waymo over school bus safety violations in Austin and Atlanta\r\n            </p>\r\n            <a \r\n              href=\"/google/waymo/ntsb-investigation-school-bus-violations\"\r\n              class=\"ml-auto shrink-0 bg-white text-red-600 px-4 py-2 rounded font-semibold hover:bg-gray-100 transition-colors text-sm\"\r\n            >\r\n              Read Full Story →\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      \r\n      <div class=\"bg-gray-50 border-y border-gray-200\">\r\n        <div class=\"container mx-auto px-4 py-8 max-w-7xl\">\r\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\">\r\n            {keyStats.map((stat) => (\r\n              <div class=\"text-center\">\r\n                <div class=\"text-3xl font-bold text-gray-900 mb-1\">{stat.value}</div>\r\n                <div class=\"text-sm text-gray-600 mb-1\">{stat.label}</div>\r\n                <div class=\"text-xs text-gray-500\">{stat.sublabel}</div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      \r\n      <div class=\"container mx-auto px-4 py-12 max-w-7xl\">\r\n        \r\n        \r\n        <section class=\"mb-16\">\r\n          <div class=\"flex items-center justify-between mb-8\">\r\n            <h2 class=\"text-3xl font-bold text-gray-900\">Latest News</h2>\r\n            <a href=\"/news\" class=\"text-blue-600 hover:text-blue-800 font-medium\">\r\n              View all news →\r\n            </a>\r\n          </div>\r\n\r\n          <div class=\"space-y-6\">\r\n            {latestNews.map((article) => (\r\n              <article\r\n                class=\"border-2 border-red-500 rounded-lg overflow-hidden hover:shadow-xl transition-shadow bg-red-50/30\"\r\n              >\r\n                <a href={`/${article.slug}`} class=\"block\">\r\n                  <div class=\"p-8\">\r\n                    <div class=\"flex items-center gap-2 mb-4\">\r\n                      <span class=\"bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full animate-pulse\">\r\n                        BREAKING\r\n                      </span>\r\n                      <span class=\"text-xs font-bold text-red-700 uppercase\">\r\n                        {article.category}\r\n                      </span>\r\n                    </div>\r\n                    \r\n                    <h3 class=\"text-2xl md:text-3xl font-bold text-gray-900 mb-4 hover:text-red-600 transition-colors\">\r\n                      {article.title}\r\n                    </h3>\r\n                    \r\n                    <p class=\"text-lg text-gray-700 mb-4 leading-relaxed\">\r\n                      {article.excerpt}\r\n                    </p>\r\n                    \r\n                    <div class=\"flex items-center justify-between\">\r\n                      <span class=\"text-sm text-gray-500\">{article.date}</span>\r\n                      <span class=\"text-red-600 font-semibold\">Read full investigation →</span>\r\n                    </div>\r\n                  </div>\r\n                </a>\r\n              </article>\r\n            ))}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-8\">About Waymo</h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 gap-8\">\r\n            <div class=\"prose prose-lg\">\r\n              <p class=\"text-gray-700 leading-relaxed mb-4\">\r\n                Waymo, formerly known as the Google Self-Driving Car Project, is an autonomous driving technology \r\n                company and a subsidiary of Alphabet Inc. Founded in 2009 and spun out as a separate company in 2016, \r\n                Waymo is widely considered the global leader in autonomous vehicle development.\r\n              </p>\r\n              \r\n              <p class=\"text-gray-700 leading-relaxed mb-4\">\r\n                The company operates commercial robotaxi services under the brand \"Waymo One\" in several major U.S. \r\n                cities, providing fully autonomous rides without human drivers. Waymo has logged over 20 million \r\n                autonomous miles on public roads and serves more than 100,000 rides per day.\r\n              </p>\r\n              \r\n              <p class=\"text-gray-700 leading-relaxed\">\r\n                Despite its technological leadership, Waymo has faced increasing scrutiny over safety incidents, \r\n                including recent federal investigations into its vehicles illegally passing stopped school buses—a \r\n                serious violation that puts children at risk.\r\n              </p>\r\n            </div>\r\n\r\n            <div class=\"bg-blue-50 p-6 rounded-lg border border-blue-200\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-4\">Current Operations</h3>\r\n              \r\n              <div class=\"space-y-4\">\r\n                <div>\r\n                  <h4 class=\"font-semibold text-gray-900 mb-2\">🌆 Operating Cities:</h4>\r\n                  <ul class=\"text-sm text-gray-700 space-y-1\">\r\n                    <li>• Phoenix, Arizona (Waymo One)</li>\r\n                    <li>• San Francisco, California (Waymo One)</li>\r\n                    <li>• Los Angeles, California (Waymo One)</li>\r\n                    <li>• Austin, Texas (Testing & Limited Service)</li>\r\n                    <li>• Atlanta, Georgia (Testing)</li>\r\n                  </ul>\r\n                </div>\r\n\r\n                <div>\r\n                  <h4 class=\"font-semibold text-gray-900 mb-2\">🚙 Fleet:</h4>\r\n                  <p class=\"text-sm text-gray-700\">\r\n                    Primary: Jaguar I-PACE electric SUVs equipped with Waymo's 5th generation autonomous driving system\r\n                  </p>\r\n                </div>\r\n\r\n                <div>\r\n                  <h4 class=\"font-semibold text-gray-900 mb-2\">🔬 Technology:</h4>\r\n                  <p class=\"text-sm text-gray-700\">\r\n                    LiDAR, radar, cameras, AI/ML systems, proprietary mapping and sensor fusion technology\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-8\">Waymo Timeline</h2>\r\n          \r\n          <div class=\"relative\">\r\n            \r\n            <div class=\"absolute left-8 top-0 bottom-0 w-0.5 bg-blue-200\"></div>\r\n            \r\n            <div class=\"space-y-8\">\r\n              {timeline.map((item, index) => (\r\n                <div class=\"relative pl-20\">\r\n                  <div class=\"absolute left-0 w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold border-4 border-white shadow-lg\">\r\n                    {item.year.slice(-2)}\r\n                  </div>\r\n                  <div class=\"bg-white p-6 rounded-lg shadow-md border border-gray-200\">\r\n                    <div class=\"font-bold text-blue-600 mb-1\">{item.year}</div>\r\n                    <div class=\"text-gray-900\">{item.event}</div>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16 bg-red-50 p-8 rounded-lg border-2 border-red-200\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6\">⚠️ Safety Investigations</h2>\r\n          \r\n          <div class=\"space-y-6\">\r\n            <div class=\"bg-white p-6 rounded-lg border border-red-300\">\r\n              <div class=\"flex items-start gap-4\">\r\n                <div class=\"bg-red-600 text-white px-3 py-1 rounded font-bold text-sm shrink-0\">\r\n                  ACTIVE\r\n                </div>\r\n                <div class=\"flex-1\">\r\n                  <h3 class=\"text-xl font-bold text-gray-900 mb-2\">NTSB Investigation (January 2026)</h3>\r\n                  <p class=\"text-gray-700 mb-3\">\r\n                    National Transportation Safety Board opens federal investigation after 20+ incidents of Waymo \r\n                    vehicles illegally passing stopped school buses with deployed stop arms in Austin, TX and Atlanta, GA.\r\n                  </p>\r\n                  <a \r\n                    href=\"/google/waymo/ntsb-investigation-school-bus-violations\"\r\n                    class=\"text-red-600 font-semibold hover:text-red-800\"\r\n                  >\r\n                    Read full report →\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"bg-white p-6 rounded-lg border border-orange-300\">\r\n              <div class=\"flex items-start gap-4\">\r\n                <div class=\"bg-orange-600 text-white px-3 py-1 rounded font-bold text-sm shrink-0\">\r\n                  ACTIVE\r\n                </div>\r\n                <div class=\"flex-1\">\r\n                  <h3 class=\"text-xl font-bold text-gray-900 mb-2\">NHTSA Investigation (October 2025)</h3>\r\n                  <p class=\"text-gray-700\">\r\n                    National Highway Traffic Safety Administration opens preliminary evaluation after Waymo vehicle \r\n                    in Atlanta failed to stop for school bus with flashing red lights and deployed stop arm.\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"mt-6 p-4 bg-yellow-50 border border-yellow-300 rounded-lg\">\r\n            <p class=\"text-sm text-gray-700\">\r\n              <strong>Note:</strong> These investigations represent the first federal safety probes into Waymo's \r\n              operations since the company began commercial service. The outcomes could significantly impact autonomous \r\n              vehicle regulation nationwide.\r\n            </p>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section>\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-8\">Our Waymo Coverage</h2>\r\n          \r\n          <div class=\"grid md:grid-cols-3 gap-6\">\r\n            <div class=\"p-6 bg-gradient-to-br from-red-50 to-red-100 rounded-lg border border-red-200\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">⚠️ Safety & Regulation</h3>\r\n              <p class=\"text-gray-700 mb-4 text-sm\">\r\n                Federal investigations, safety incidents, regulatory compliance, and public safety concerns.\r\n              </p>\r\n              <a href=\"/google/waymo/ntsb-investigation-school-bus-violations\" class=\"text-red-600 font-medium hover:text-red-800 text-sm\">\r\n                View safety coverage →\r\n              </a>\r\n            </div>\r\n            \r\n            <div class=\"p-6 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg border border-blue-200\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">🔬 Technology</h3>\r\n              <p class=\"text-gray-700 mb-4 text-sm\">\r\n                Autonomous driving systems, AI/ML developments, sensor technology, and innovation updates.\r\n              </p>\r\n              <a href=\"/google\" class=\"text-blue-600 font-medium hover:text-blue-800 text-sm\">\r\n                View tech coverage →\r\n              </a>\r\n            </div>\r\n            \r\n            <div class=\"p-6 bg-gradient-to-br from-green-50 to-green-100 rounded-lg border border-green-200\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">📊 Business</h3>\r\n              <p class=\"text-gray-700 mb-4 text-sm\">\r\n                Market expansion, partnerships, financial performance, and competitive analysis.\r\n              </p>\r\n              <a href=\"/analyst\" class=\"text-green-600 font-medium hover:text-green-800 text-sm\">\r\n                View business coverage →\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n      </div>\r\n\r\n      \r\n      <div class=\"bg-gradient-to-r from-blue-600 to-cyan-600 text-white\">\r\n        <div class=\"container mx-auto px-4 py-12 max-w-4xl text-center\">\r\n          <h2 class=\"text-3xl font-bold mb-4\">Stay Updated on Waymo</h2>\r\n          <p class=\"text-xl text-gray-100 mb-6\">\r\n            Get breaking news on autonomous vehicle safety, investigations, and technology developments.\r\n          </p>\r\n          <div class=\"flex gap-4 justify-center\">\r\n            <a\r\n              href=\"/google/waymo/ntsb-investigation-school-bus-violations\"\r\n              class=\"bg-red-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-700 transition-colors\"\r\n            >\r\n              Read NTSB Investigation\r\n            </a>\r\n            <a\r\n              href=\"/news\"\r\n              class=\"bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors\"\r\n            >\r\n              All News\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </main>"
