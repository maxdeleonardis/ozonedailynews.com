{
  "name": "ozonedailynews.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "prebuild": "npx ts-node --project tsconfig.scripts.json scripts/validate-public.ts && npx ts-node --project tsconfig.scripts.json scripts/validate-canonicals.ts && npx ts-node --project tsconfig.scripts.json scripts/sync-registry.ts --write",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "alfasa": "npx ts-node --project tsconfig.scripts.json scripts/alfasa-suggest.ts",
    "wiki:sync": "npx ts-node --project tsconfig.scripts.json scripts/sync-registry.ts",
    "wiki:publish": "npx ts-node --project tsconfig.scripts.json scripts/alfasa-sentinel.ts",
    "validate:eeat": "npx ts-node --project tsconfig.scripts.json scripts/validate-eeat.ts",
    "validate:eeat:strict": "cross-env EEAT_STRICT=true npx ts-node --project tsconfig.scripts.json scripts/validate-eeat.ts",
    "validate:geo": "npx ts-node --project tsconfig.scripts.json scripts/validate-geo.ts",
    "validate:canonicals": "npx ts-node --project tsconfig.scripts.json scripts/validate-canonicals.ts",
    "lifecycle:check": "npx ts-node --project tsconfig.scripts.json scripts/lifecycle-manager.ts --check",
    "lifecycle:promote": "npx ts-node --project tsconfig.scripts.json scripts/lifecycle-manager.ts --promote",
    "lifecycle:prune": "npx ts-node --project tsconfig.scripts.json scripts/lifecycle-manager.ts --prune",
    "ping:indexers": "npx ts-node --project tsconfig.scripts.json scripts/ping-indexers.ts",
    "backfill": "npx ts-node --project tsconfig.scripts.json scripts/backfill-articles.ts",
    "rss:digest": "npx ts-node --project tsconfig.scripts.json scripts/rss-digest.ts"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.6.0",
    "ts-node": "^10.9.2"
  },
  "optionalDependencies": {
    "@resvg/resvg-js-darwin-arm64": "^2.6.2",
    "@resvg/resvg-js-linux-x64-gnu": "^2.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fast-xml-parser": "^5.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "uuid": "^14.0.0"
  }
}
