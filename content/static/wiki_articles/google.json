  "content": [
    {
      "id": "html-body",
      "type": "html",
      "content": "<main class=\"min-h-screen bg-white\">\r\n      \r\n      <div class=\"bg-gradient-to-r from-blue-600 via-red-500 to-yellow-500 text-white\">\r\n        <div class=\"container mx-auto px-4 py-16 max-w-7xl\">\r\n          <div class=\"max-w-4xl\">\r\n            <div class=\"flex items-center gap-3 mb-4\">\r\n              <span class=\"text-5xl\">🔍</span>\r\n              <h1 class=\"text-5xl md:text-6xl font-bold\">\r\n                Google & Alphabet Inc\r\n              </h1>\r\n            </div>\r\n            <p class=\"text-xl text-gray-100 leading-relaxed mb-6\">\r\n              Comprehensive coverage of Google, Alphabet Inc, and its family of companies. From search and AI \r\n              to autonomous vehicles and life sciences, track the innovations shaping the future of technology.\r\n            </p>\r\n            <div class=\"flex flex-wrap gap-4 text-sm\">\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Search & Advertising</span>\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Artificial Intelligence</span>\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Autonomous Vehicles</span>\r\n              <span class=\"bg-white/20 px-4 py-2 rounded-full\">Cloud Computing</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      \r\n      <div class=\"bg-gray-50 border-y border-gray-200\">\r\n        <div class=\"container mx-auto px-4 py-8 max-w-7xl\">\r\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\">\r\n            {businessMetrics.map((metric) => (\r\n              <div class=\"text-center\">\r\n                <div class=\"text-3xl font-bold text-gray-900 mb-1\">{metric.value}</div>\r\n                <div class=\"text-sm text-gray-600 mb-1\">{metric.label}</div>\r\n                {metric.change && (\r\n                  <div class={`text-xs font-semibold ${\r\n                    metric.change.startsWith('+') ? 'text-green-600' : 'text-gray-500'\r\n                  }`}>\r\n                    {metric.change}\r\n                  </div>\r\n                )}\r\n                {metric.year && (\r\n                  <div class=\"text-xs text-gray-500\">{metric.year}</div>\r\n                )}\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      \r\n      <div class=\"container mx-auto px-4 py-12 max-w-7xl\">\r\n        \r\n        \r\n        <section class=\"mb-16\">\r\n          <div class=\"flex items-center justify-between mb-8\">\r\n            <h2 class=\"text-3xl font-bold text-gray-900\">Latest News & Updates</h2>\r\n            <a href=\"/news\" class=\"text-blue-600 hover:text-blue-800 font-medium\">\r\n              View all news →\r\n            </a>\r\n          </div>\r\n\r\n          <div class=\"grid md:grid-cols-2 gap-8\">\r\n            {recentNews.map((article) => (\r\n              <article\r\n                class={`border rounded-lg overflow-hidden hover:shadow-xl transition-shadow ${\r\n                  article.urgent ? 'border-red-500 border-2' : 'border-gray-200'\r\n                }`}\r\n              >\r\n                <a href={`/${article.slug}`} class=\"block\">\r\n                  <div class=\"p-6\">\r\n                    <div class=\"flex items-center gap-2 mb-3\">\r\n                      <span class={`text-xs font-bold px-3 py-1 rounded-full ${\r\n                        article.urgent \r\n                          ? 'bg-red-100 text-red-700' \r\n                          : 'bg-blue-100 text-blue-700'\r\n                      }`}>\r\n                        {article.category}\r\n                      </span>\r\n                      {article.urgent && (\r\n                        <span class=\"bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full animate-pulse\">\r\n                          BREAKING\r\n                        </span>\r\n                      )}\r\n                    </div>\r\n                    \r\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3 hover:text-blue-600 transition-colors\">\r\n                      {article.title}\r\n                    </h3>\r\n                    \r\n                    <p class=\"text-gray-600 mb-4 leading-relaxed\">\r\n                      {article.excerpt}\r\n                    </p>\r\n                    \r\n                    <div class=\"flex items-center justify-between text-sm text-gray-500\">\r\n                      <span>{article.date}</span>\r\n                      <span class=\"text-blue-600 font-medium\">Read more →</span>\r\n                    </div>\r\n                  </div>\r\n                </a>\r\n              </article>\r\n            ))}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-8\">Alphabet Companies & Subsidiaries</h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n            {subsidiaries.map((company) => (\r\n              <a\r\n                href={`/${company.slug}`}\r\n                class=\"block p-6 border border-gray-200 rounded-lg hover:border-blue-400 hover:shadow-lg transition-all group\"\r\n              >\r\n                <div class=\"text-4xl mb-4\">{company.icon}</div>\r\n                <h3 class=\"text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600\">\r\n                  {company.name}\r\n                </h3>\r\n                <p class=\"text-gray-600 text-sm leading-relaxed\">\r\n                  {company.description}\r\n                </p>\r\n                <div class=\"mt-4 text-blue-600 text-sm font-medium\">\r\n                  Learn more →\r\n                </div>\r\n              </a>\r\n            ))}\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section class=\"mb-16 bg-gray-50 p-8 rounded-lg\">\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-6\">About Alphabet Inc</h2>\r\n          \r\n          <div class=\"prose prose-lg max-w-none\">\r\n            <p class=\"text-gray-700 leading-relaxed mb-4\">\r\n              Alphabet Inc. is an American multinational technology conglomerate holding company headquartered in \r\n              Mountain View, California. Created in 2015 through a corporate restructuring of Google, Alphabet is \r\n              the parent company of Google and several former Google subsidiaries.\r\n            </p>\r\n            \r\n            <p class=\"text-gray-700 leading-relaxed mb-4\">\r\n              The company is organized around several key business areas including internet services, autonomous \r\n              vehicles, life sciences, investment capital, and research. Google remains Alphabet's largest subsidiary \r\n              and primary revenue generator, accounting for the vast majority of the company's income through \r\n              advertising, cloud computing, and hardware sales.\r\n            </p>\r\n            \r\n            <div class=\"bg-white p-6 rounded-lg border border-gray-200 mt-6\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-4\">Key Milestones</h3>\r\n              <ul class=\"space-y-3\">\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">1998</span>\r\n                  <span class=\"text-gray-700\">Google founded by Larry Page and Sergey Brin at Stanford</span>\r\n                </li>\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">2004</span>\r\n                  <span class=\"text-gray-700\">Google goes public (IPO)</span>\r\n                </li>\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">2006</span>\r\n                  <span class=\"text-gray-700\">Acquires YouTube for $1.65 billion</span>\r\n                </li>\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">2009</span>\r\n                  <span class=\"text-gray-700\">Launches Waymo self-driving car project</span>\r\n                </li>\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">2014</span>\r\n                  <span class=\"text-gray-700\">Acquires DeepMind for $500 million</span>\r\n                </li>\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">2015</span>\r\n                  <span class=\"text-gray-700\">Restructures as Alphabet Inc.</span>\r\n                </li>\r\n                <li class=\"flex gap-3\">\r\n                  <span class=\"font-bold text-blue-600 min-w-[80px]\">2026</span>\r\n                  <span class=\"text-gray-700\">Partners with Apple on Gemini AI integration</span>\r\n                </li>\r\n              </ul>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n        \r\n        <section>\r\n          <h2 class=\"text-3xl font-bold text-gray-900 mb-8\">Our Coverage</h2>\r\n          \r\n          <div class=\"grid md:grid-cols-2 gap-6\">\r\n            <div class=\"p-6 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">🤖 Artificial Intelligence</h3>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                Coverage of Google's AI research, Gemini development, DeepMind breakthroughs, and machine learning innovations.\r\n              </p>\r\n              <a href=\"/news?category=ai\" class=\"text-blue-600 font-medium hover:text-blue-800\">\r\n                View AI coverage →\r\n              </a>\r\n            </div>\r\n            \r\n            <div class=\"p-6 bg-gradient-to-br from-green-50 to-green-100 rounded-lg\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">🚗 Autonomous Vehicles</h3>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                In-depth reporting on Waymo's self-driving technology, safety investigations, and the future of transportation.\r\n              </p>\r\n              <a href=\"/google/waymo\" class=\"text-green-600 font-medium hover:text-green-800\">\r\n                View Waymo coverage →\r\n              </a>\r\n            </div>\r\n            \r\n            <div class=\"p-6 bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">💼 Business & Strategy</h3>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                Analysis of Alphabet's business operations, acquisitions, financial performance, and competitive positioning.\r\n              </p>\r\n              <a href=\"/analyst\" class=\"text-purple-600 font-medium hover:text-purple-800\">\r\n                View business analysis →\r\n              </a>\r\n            </div>\r\n            \r\n            <div class=\"p-6 bg-gradient-to-br from-orange-50 to-orange-100 rounded-lg\">\r\n              <h3 class=\"text-xl font-bold text-gray-900 mb-3\">⚖️ Regulation & Policy</h3>\r\n              <p class=\"text-gray-700 mb-4\">\r\n                Coverage of antitrust investigations, privacy concerns, regulatory challenges, and policy developments.\r\n              </p>\r\n              <a href=\"/news?category=regulation\" class=\"text-orange-600 font-medium hover:text-orange-800\">\r\n                View policy coverage →\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </section>\r\n\r\n      </div>\r\n\r\n      \r\n      <div class=\"bg-gradient-to-r from-blue-600 to-purple-600 text-white\">\r\n        <div class=\"container mx-auto px-4 py-12 max-w-4xl text-center\">\r\n          <h2 class=\"text-3xl font-bold mb-4\">Stay Updated on Google & Alphabet</h2>\r\n          <p class=\"text-xl text-gray-100 mb-6\">\r\n            Get the latest news, analysis, and insights delivered to your inbox.\r\n          </p>\r\n          <div class=\"flex gap-4 justify-center\">\r\n            <a\r\n              href=\"/news\"\r\n              class=\"bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors\"\r\n            >\r\n              Latest News\r\n            </a>\r\n            <a\r\n              href=\"/contact\"\r\n              class=\"bg-transparent border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors\"\r\n            >\r\n              Subscribe\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </main>"
    }
