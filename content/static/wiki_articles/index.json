  "content": [
    {
      "id": "html-body",
      "type": "html",
      "content": "<div class=\"route-item\">\r\n      <div \r\n        class=\"flex items-start py-2 px-4 hover:bg-gray-50 rounded-lg transition-colors group\"\r\n        style={{ paddingLeft: `${indent + 16}px` }}\r\n      >\r\n        \r\n        {level > 0 && (\r\n          <div class=\"absolute left-0 top-0 bottom-0 w-px bg-gray-200\" style={{ left: `${indent - 12}px` }} />\r\n        )}\r\n        \r\n        \r\n        <span class=\"text-xl mr-3 flex-shrink-0\">\r\n          {hasChildren ? '📁' : route.hasPage ? '📄' : '📂'}\r\n        </span>\r\n        \r\n        \r\n        <div class=\"flex-1 min-w-0\">\r\n          <div class=\"flex items-center gap-3 flex-wrap\">\r\n            {route.hasPage ? (\r\n              <a \r\n                href={route.path} \r\n                class=\"font-medium text-blue-600 hover:text-blue-800 hover:underline\"\r\n              >\r\n                {formatRouteName(route.name)}\r\n              </a>\r\n            ) : (\r\n              <span class=\"font-medium text-gray-700\">\r\n                {formatRouteName(route.name)}\r\n              </span>\r\n            )}\r\n            \r\n            <span class=\"text-xs text-gray-500 font-mono bg-gray-100 px-2 py-1 rounded\">\r\n              {route.path || '/'}\r\n            </span>\r\n            \r\n            {!route.hasPage && hasChildren && (\r\n              <span class=\"text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded\">\r\n                Section\r\n              </span>\r\n            )}\r\n          </div>\r\n          \r\n          {hasChildren && (\r\n            <div class=\"text-xs text-gray-500 mt-1\">\r\n              {route.children.length} {route.children.length === 1 ? 'page' : 'pages'}\r\n            </div>\r\n          )}\r\n        </div>\r\n      </div>\r\n      \r\n      \r\n      {hasChildren && (\r\n        <div class=\"relative\">\r\n          {route.children.map((child, index) => (\r\n            <RouteTreeItem route={child} level={level + 1} />\r\n          ))}\r\n        </div>\r\n      )}\r\n    </div>"
    }
  ],
