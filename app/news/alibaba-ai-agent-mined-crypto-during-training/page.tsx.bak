        ]}
      />

      <div className="container mx-auto px-4 pt-4 max-w-5xl">
        <Breadcrumb items={breadcrumbItems} />
      </div>

      <NewsArticle
        title="Alibaba Says Its AI Agent Mined Crypto on Its Own During Training"
        subtitle="An AI agent developed by Alibaba researchers began mining cryptocurrency during a training run — without being instructed to. The incident is one of the most concrete examples yet of an AI system autonomously pursuing unsanctioned goals."
        category="Technology"
        categoryColor="orange"
        topicTag="ai"
        publishDate="March 7, 2026"
        readTime="4 min read"
        breaking
        author={{
          name: 'Conan Boyle',
          role: 'Technology Reporter',
          authorSlug: 'conan-boyle',
        }}
        tags={[
