{
  "name": "objectwire-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "npx tsx scripts/sync-registry.ts --write",
    "build": "next build --turbopack",
    "start": "next start",
    "import-blogs": "npx tsx scripts/import-rss-to-blocks.ts",
    "sitemap:update": "npx tsx scripts/update-sitemap.ts",
    "sitemap:ping": "npx tsx scripts/update-sitemap.ts --ping",
    "registry:sync": "npx tsx scripts/sync-registry.ts",
    "registry:write": "npx tsx scripts/sync-registry.ts --write",
    "db:push": "npx supabase db push",
    "db:status": "npx supabase migration list",
    "db:new": "npx supabase migration new",
    "articles:push": "npx tsx scripts/push-articles-to-supabase.ts",
    "articles:dry-run": "npx tsx scripts/push-articles-to-supabase.ts --dry-run",
    "content:publish": "npx tsx scripts/publish-content.ts",
    "content:dry-run": "npx tsx scripts/publish-content.ts --dry-run",
    "wiki:migrate": "npx tsx scripts/migrate-wiki-content.ts",
    "wiki:migrate-dry": "npx tsx scripts/migrate-wiki-content.ts --dry-run",
    "wiki:trim": "npx tsx scripts/trim-wiki-pages.ts",
    "wiki:trim-dry": "npx tsx scripts/trim-wiki-pages.ts --dry-run",
    "pipeline:local": "npm run wiki:migrate && npm run wiki:trim && npm run registry:write && npx tsx scripts/ping-google.ts",
    "wiki:sync": "npx tsx scripts/sync-wiki-content.ts",
    "wiki:sync-dry": "npx tsx scripts/sync-wiki-content.ts --dry-run",
    "media:sync": "npx tsx scripts/sync-public-to-supabase.ts",
    "media:sync-dry": "npx tsx scripts/sync-public-to-supabase.ts --dry-run",
    "media:overwrite": "npx tsx scripts/sync-public-to-supabase.ts --overwrite",
    "prepare": "husky"
  },
  "lint-staged": {
    "app/**/**/page.tsx": [
      "npx tsx --env-file=.env.local scripts/migrate-wiki-content.ts --file"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-underline": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "date-fns": "^4.1.0",
    "feather-icons": "^4.29.2",
    "framer-motion": "^12.23.24",
    "google-auth-library": "^10.6.1",
    "lucide-react": "^0.548.0",
    "next": "^15.5.9",
    "next-auth": "^4.24.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-ga4": "^2.1.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xml2js": "^0.4.14",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mime-types": "^3.0.2",
    "supabase": "^2.72.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "xml2js": "^0.6.2"
  }
}
