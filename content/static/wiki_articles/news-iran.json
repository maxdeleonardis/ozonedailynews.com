      "content": "<div class=\"min-h-screen bg-gradient-to-b from-gray-50 to-white\">\r\n      \r\n      <section class=\"bg-black text-white py-20 border-b border-gray-800\">\r\n        <div class=\"container max-w-6xl\">\r\n          <div class=\"flex items-center gap-3 mb-6\">\r\n            <div class=\"w-12 h-12 bg-red-600 flex items-center justify-center rounded\">\r\n              <span class=\"text-2xl\">🇮🇷</span>\r\n            </div>\r\n            <span class=\"text-sm font-mono text-gray-400 tracking-wider\">LIVE COVERAGE</span>\r\n          </div>\r\n          <h1 class=\"text-5xl md:text-6xl font-bold mb-6\">Iran News Hub</h1>\r\n          <p class=\"text-xl text-gray-300 leading-relaxed max-w-3xl\">\r\n            Comprehensive verified intelligence on the 2026 Iranian Revolution, political developments, \r\n            and regional impact. Real-time updates from primary sources with full citation transparency.\r\n          </p>\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"bg-red-50 border-b border-red-100 py-6\">\r\n        <div class=\"container max-w-6xl\">\r\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n            <div class=\"text-center\">\r\n              <div class=\"text-3xl font-bold text-red-600 mb-1\">Jan 2026</div>\r\n              <div class=\"text-sm text-gray-600\">Ongoing Developments</div>\r\n            </div>\r\n            <div class=\"text-center\">\r\n              <div class=\"text-3xl font-bold text-red-600 mb-1\">{iranPosts.length}</div>\r\n              <div class=\"text-sm text-gray-600\">Verified Reports</div>\r\n            </div>\r\n            <div class=\"text-center\">\r\n              <div class=\"text-3xl font-bold text-red-600 mb-1\">Live</div>\r\n              <div class=\"text-sm text-gray-600\">Coverage Status</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"py-12 border-b border-gray-200\">\r\n        <div class=\"container max-w-6xl\">\r\n          <h2 class=\"text-3xl font-bold mb-8\">2026 Iranian Revolution Timeline</h2>\r\n          <div class=\"space-y-6\">\r\n            <div class=\"flex gap-4 pb-6 border-b border-gray-200\">\r\n              <div class=\"flex-shrink-0 w-32 text-sm font-mono text-gray-500\">JAN 2026</div>\r\n              <div>\r\n                <h3 class=\"font-semibold mb-2\">Revolutionary Escalation</h3>\r\n                <p class=\"text-gray-600 leading-relaxed\">\r\n                  Mass demonstrations intensify across major Iranian cities. Protests expand beyond \r\n                  economic grievances to calls for fundamental political change. Security forces \r\n                  deployment increases in Tehran, Mashhad, and Isfahan.\r\n                </p>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"flex gap-4 pb-6 border-b border-gray-200\">\r\n              <div class=\"flex-shrink-0 w-32 text-sm font-mono text-gray-500\">DEC 2025</div>\r\n              <div>\r\n                <h3 class=\"font-semibold mb-2\">Initial Protests</h3>\r\n                <p class=\"text-gray-600 leading-relaxed\">\r\n                  Economic protests emerge in response to currency devaluation and inflation. \r\n                  Student-led demonstrations spread to provincial cities. Internet restrictions \r\n                  implemented intermittently.\r\n                </p>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"flex gap-4\">\r\n              <div class=\"flex-shrink-0 w-32 text-sm font-mono text-gray-500\">NOV 2025</div>\r\n              <div>\r\n                <h3 class=\"font-semibold mb-2\">Pre-Revolution Context</h3>\r\n                <p class=\"text-gray-600 leading-relaxed\">\r\n                  Rising tensions over economic conditions, government policies, and regional \r\n                  diplomatic isolation. Civil society organizations increase coordination despite \r\n                  government pressure.\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"py-16\">\r\n        <div class=\"container max-w-6xl\">\r\n          <div class=\"flex items-center justify-between mb-10\">\r\n            <h2 class=\"text-3xl font-bold\">Latest Iran Coverage</h2>\r\n            <span class=\"text-sm text-gray-500\">{iranPosts.length} verified reports</span>\r\n          </div>\r\n\r\n          {iranPosts.length > 0 ? (\r\n            <div class=\"grid gap-8\">\r\n              {iranPosts.map((post: any) => (\r\n                <article \r\n                  class=\"bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow\"\r\n                >\r\n                  <div class=\"flex items-start justify-between gap-6\">\r\n                    <div class=\"flex-1\">\r\n                      <div class=\"flex items-center gap-3 mb-3\">\r\n                        <span class=\"px-3 py-1 bg-red-50 text-red-600 text-xs font-semibold rounded-full border border-red-200\">\r\n                          {post.category}\r\n                        </span>\r\n                        <span class=\"text-xs text-gray-500 font-mono\">\r\n                          {new Date(post.publishedAt || post.published_at || post.created_at || Date.now()).toLocaleDateString('en-US', {\r\n                            month: 'short',\r\n                            day: 'numeric',\r\n                            year: 'numeric'\r\n                          })}\r\n                        </span>\r\n                      </div>\r\n                      \r\n                      <a href={`/${post.slug}`}>\r\n                        <h3 class=\"text-2xl font-bold mb-3 hover:text-red-600 transition-colors cursor-pointer\">\r\n                          {post.title}\r\n                        </h3>\r\n                      </a>\r\n                      \r\n                      {post.excerpt && (\r\n                        <p class=\"text-gray-600 leading-relaxed mb-4 line-clamp-2\">\r\n                          {post.excerpt}\r\n                        </p>\r\n                      )}\r\n                      \r\n                      <div class=\"flex items-center gap-4 text-sm text-gray-500\">\r\n                        <span>By {post.author || 'ObjectWire Team'}</span>\r\n                        <span>•</span>\r\n                        <span>{post.read_time || '5 min'}</span>\r\n                        {post.tags && post.tags.length > 0 && (\r\n                          <>\r\n                            <span>•</span>\r\n                            <div class=\"flex gap-2\">\r\n                              {post.tags.slice(0, 3).map((tag: string) => (\r\n                                <span class=\"px-2 py-0.5 bg-gray-100 rounded text-xs\">\r\n                                  {tag}\r\n                                </span>\r\n                              ))}\r\n                            </div>\r\n                          </>\r\n                        )}\r\n                      </div>\r\n                    </div>\r\n                    \r\n                    <a href={`/${post.slug}`}>\r\n                      <button class=\"px-6 py-2 bg-black text-white text-sm font-medium hover:bg-gray-800 transition-colors rounded\">\r\n                        Read Report →\r\n                      </button>\r\n                    </a>\r\n                  </div>\r\n                </article>\r\n              ))}\r\n            </div>\r\n          ) : (\r\n            <div class=\"bg-gray-50 border border-gray-200 rounded-lg p-12 text-center\">\r\n              <div class=\"text-5xl mb-4\">📰</div>\r\n              <h3 class=\"text-xl font-semibold mb-2\">No Iran Coverage Yet</h3>\r\n              <p class=\"text-gray-600 mb-6\">\r\n                Iran-related articles will appear here as they are published. \r\n                Check back soon for the latest verified intelligence.\r\n              </p>\r\n              <a href=\"/\">\r\n                <button class=\"px-6 py-3 bg-black text-white font-medium hover:bg-gray-800 transition-colors\">\r\n                  Browse All News\r\n                </button>\r\n              </a>\r\n            </div>\r\n          )}\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"py-16 bg-gray-50 border-t border-gray-200\">\r\n        <div class=\"container max-w-6xl\">\r\n          <h2 class=\"text-3xl font-bold mb-8\">Key Topics</h2>\r\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\r\n            <div class=\"bg-white p-6 rounded-lg border border-gray-200\">\r\n              <div class=\"text-3xl mb-3\">🏛️</div>\r\n              <h3 class=\"text-xl font-semibold mb-2\">Political Developments</h3>\r\n              <p class=\"text-gray-600 text-sm\">\r\n                Government responses, policy changes, and leadership statements regarding \r\n                the ongoing situation.\r\n              </p>\r\n            </div>\r\n            \r\n            <div class=\"bg-white p-6 rounded-lg border border-gray-200\">\r\n              <div class=\"text-3xl mb-3\">📊</div>\r\n              <h3 class=\"text-xl font-semibold mb-2\">Economic Impact</h3>\r\n              <p class=\"text-gray-600 text-sm\">\r\n                Currency fluctuations, sanctions effects, and economic measures implemented \r\n                during the crisis period.\r\n              </p>\r\n            </div>\r\n            \r\n            <div class=\"bg-white p-6 rounded-lg border border-gray-200\">\r\n              <div class=\"text-3xl mb-3\">🌍</div>\r\n              <h3 class=\"text-xl font-semibold mb-2\">Regional Effects</h3>\r\n              <p class=\"text-gray-600 text-sm\">\r\n                International responses, diplomatic developments, and regional security \r\n                implications of events in Iran.\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"py-12 bg-blue-50 border-y border-blue-100\">\r\n        <div class=\"container max-w-6xl\">\r\n          <div class=\"flex items-start gap-4\">\r\n            <div class=\"text-3xl\">✓</div>\r\n            <div>\r\n              <h3 class=\"text-xl font-semibold mb-2\">Verification Standards</h3>\r\n              <p class=\"text-gray-700 leading-relaxed\">\r\n                All Iran coverage is verified using primary sources and cross-referenced with \r\n                multiple independent reports. Claims are documented with full source citations. \r\n                Updates are made in real-time as new verified information becomes available.\r\n              </p>\r\n              <a href=\"/editorial-standards\" class=\"text-blue-600 hover:text-blue-700 font-medium mt-3 inline-block\">\r\n                Read our editorial standards →\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"py-16\">\r\n        <div class=\"container max-w-6xl text-center\">\r\n          <h2 class=\"text-3xl font-bold mb-4\">Stay Informed</h2>\r\n          <p class=\"text-xl text-gray-600 mb-8 max-w-2xl mx-auto\">\r\n            Get real-time updates on Iran developments with verified, source-cited intelligence.\r\n          </p>\r\n          <div class=\"flex gap-4 justify-center\">\r\n            <a href=\"/\">\r\n              <button class=\"px-8 py-4 bg-black text-white font-semibold hover:bg-gray-800 transition-colors rounded\">\r\n                View All Coverage\r\n              </button>\r\n            </a>\r\n            <a href=\"/about\">\r\n              <button class=\"px-8 py-4 border-2 border-black text-black font-semibold hover:bg-gray-50 transition-colors rounded\">\r\n                About ObjectWire\r\n              </button>\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </div>"
