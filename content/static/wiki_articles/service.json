      "content": "<main class=\"min-h-screen bg-[#faf9f6]\">\r\n      \r\n      <section class=\"bg-gradient-to-b from-gray-900 to-gray-800 text-white\">\r\n        <div class=\"container mx-auto px-4 py-20 max-w-5xl\">\r\n          <nav class=\"text-sm text-gray-400 mb-8\">\r\n            <a href=\"/\" class=\"hover:text-white transition-colors\">\r\n              Home\r\n            </a>\r\n            <span class=\"mx-2\">/</span>\r\n            <span class=\"text-white\">Services</span>\r\n          </nav>\r\n\r\n          <div class=\"flex items-start gap-6 mb-6\">\r\n            <div class=\"hidden sm:flex w-16 h-16 bg-white/10 rounded-xl items-center justify-center shrink-0\">\r\n              <span class=\"text-3xl\">🔍</span>\r\n            </div>\r\n            <div>\r\n              <p class=\"text-blue-400 text-xs font-mono tracking-widest mb-3\">\r\n                LICENSED PRIVATE DETECTIVE AGENCY • AUSTIN, TX\r\n              </p>\r\n              <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-4\">\r\n                Investigative &amp;&nbsp;Media Services\r\n              </h1>\r\n              <p class=\"text-lg text-gray-300 max-w-2xl leading-relaxed\">\r\n                OzoneNews is a licensed private detective agency based in Austin, Texas. We combine\r\n                traditional investigative expertise with cutting-edge digital forensics to deliver\r\n                court-admissible results with complete confidentiality.\r\n              </p>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"flex flex-wrap gap-3 mt-8\">\r\n            <a\r\n              href=\"/austin-private-detective-agency\"\r\n              class=\"px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors\"\r\n            >\r\n              About Our Agency →\r\n            </a>\r\n            <a\r\n              href=\"/get-help/contact\"\r\n              class=\"px-5 py-2.5 border border-gray-500 text-white text-sm font-semibold rounded-lg hover:bg-white/10 transition-colors\"\r\n            >\r\n              Request Consultation\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      \r\n      <section class=\"container mx-auto px-4 -mt-8 max-w-5xl relative z-10 mb-12\">\r\n        <a\r\n          href=\"/austin-private-detective-agency\"\r\n          class=\"group block bg-white border border-gray-200 rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow\"\r\n        >\r\n          <div class=\"flex items-center gap-3 mb-3\">\r\n            <span class=\"text-3xl\">🕵️</span>\r\n            <div>\r\n              <span class=\"text-[10px] font-bold tracking-widest text-blue-600 uppercase\">\r\n                Featured\r\n              </span>\r\n              <h2 class=\"text-2xl font-black text-gray-900 group-hover:text-blue-700 transition-colors\">\r\n                Austin Private Detective Agency\r\n              </h2>\r\n            </div>\r\n          </div>\r\n          <p class=\"text-gray-600 leading-relaxed mb-4 max-w-3xl\">\r\n            Our digital forensics unit uncovers hidden email accounts, social-media aliases,\r\n            cryptocurrency transactions, and dark-web references linked to harassment, fraud, and\r\n            other criminal activities. We provide discreet, professional investigative services\r\n            throughout Texas and beyond.\r\n          </p>\r\n          <div class=\"flex flex-wrap gap-2\">\r\n            {[\"Digital Forensics\", \"Background Checks\", \"Cryptocurrency Tracking\", \"Dark Web Monitoring\", \"Corporate Investigations\"].map(\r\n              (tag) => (\r\n                <span\r\n                  class=\"px-2.5 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-full\"\r\n                >\r\n                  {tag}\r\n                </span>\r\n              )\r\n            )}\r\n          </div>\r\n        </a>\r\n      </section>\r\n\r\n      \r\n      <section class=\"container mx-auto px-4 max-w-5xl pb-20\">\r\n        <div class=\"flex items-center gap-4 mb-8\">\r\n          <div class=\"h-px flex-1 bg-gray-300\" />\r\n          <h2 class=\"text-xs font-black tracking-[.3em] uppercase text-gray-500\">\r\n            Our Services\r\n          </h2>\r\n          <div class=\"h-px flex-1 bg-gray-300\" />\r\n        </div>\r\n\r\n        <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n          {SERVICES.map((service) => (\r\n            <a\r\n              href={service.href}\r\n              class=\"group bg-white border border-gray-200 rounded-xl p-6 hover:border-gray-400 hover:shadow-lg transition-all\"\r\n            >\r\n              <span class=\"text-3xl block mb-4\">{service.icon}</span>\r\n              <h3 class=\"text-lg font-bold text-gray-900 group-hover:text-blue-700 transition-colors mb-2\">\r\n                {service.title}\r\n              </h3>\r\n              <p class=\"text-sm text-gray-600 leading-relaxed mb-4 line-clamp-3\">\r\n                {service.description}\r\n              </p>\r\n              <div class=\"flex flex-wrap gap-1.5\">\r\n                {service.tags.map((tag) => (\r\n                  <span\r\n                    class=\"px-2 py-0.5 bg-gray-100 text-gray-500 text-[10px] font-semibold rounded-full tracking-wide uppercase\"\r\n                  >\r\n                    {tag}\r\n                  </span>\r\n                ))}\r\n              </div>\r\n            </a>\r\n          ))}\r\n        </div>\r\n\r\n        \r\n        <div class=\"mt-16 bg-gray-900 rounded-xl p-8 md:p-12 text-white text-center\">\r\n          <h2 class=\"text-2xl md:text-3xl font-black mb-3\">Need Professional Investigation?</h2>\r\n          <p class=\"text-gray-300 max-w-xl mx-auto mb-6\">\r\n            All consultations are confidential. Contact our licensed team for a discreet assessment\r\n            of your case.\r\n          </p>\r\n          <div class=\"flex flex-wrap justify-center gap-4\">\r\n            <a\r\n              href=\"/get-help/contact\"\r\n              class=\"px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors\"\r\n            >\r\n              Request Free Consultation\r\n            </a>\r\n            <a\r\n              href=\"/austin-private-detective-agency\"\r\n              class=\"px-6 py-3 border border-gray-500 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors\"\r\n            >\r\n              Learn About Our Agency\r\n            </a>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </main>"
